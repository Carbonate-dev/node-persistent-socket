{
  "name": "persistent-socket",
  "version": "1.0.0",
  "description": "Create a persistent socket connection that lazily reconnects when it receives writes",
  "main": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "ci": "npm run build && npm run check-format && npm run check-exports && npm run lint && npm run test",
    "check-exports": "attw --pack .",
    "lint": "tsc",
    "dev": "vitest",
    "local-release": "changeset version && changeset publish",
    "prepublishOnly": "npm run ci"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Carbonate-dev/node-persistent-socket.git"
  },
  "keywords": [
    "node",
    "socket",
    "persistent",
    "lazy",
    "connection"
  ],
  "author": "Carbonate.dev",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Carbonate-dev/node-persistent-socket/issues"
  },
  "homepage": "https://github.com/Carbonate-dev/node-persistent-socket#readme",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.3",
    "@changesets/cli": "^2.27.12",
    "@types/node": "^22.13.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "files": [
    "dist"
  ],
  "type": "module"
}
